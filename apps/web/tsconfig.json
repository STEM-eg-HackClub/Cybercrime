{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "paths": {
      "@quest/shared": ["../../shared/protocol.ts"]
    }
  },
  "include": ["src/**/*.ts", "vite.config.ts"]
}
